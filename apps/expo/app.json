{
  "expo": {
    "name": "ToboChat",
    "slug": "ToboChat",
    "scheme": "tobochat",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "updates": {
      "fallbackToCacheTimeout": 0
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.tobochat.app",
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "Cho phép ứng dụng truy cập thư viện ảnh để chọn ảnh đại diện."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FFFFFF"
      },
      "softwareKeyboardLayoutMode": "resize",
      "package": "com.tobochat.app"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-camera",
        {
          "cameraPermission": "ToboChat cần quyền truy cập Camera để bạn có thể gọi video."
        }
      ],
      [
        "expo-av",
        {
          "microphonePermission": "ToboChat cần quyền truy cập Micro để bạn có thể trò chuyện."
        }
      ],
      "@livekit/react-native"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "24633ca8-91fc-470f-bf16-4d585a42bc4f"
      }
    },
    "owner": "teamtobo"
  }
}
